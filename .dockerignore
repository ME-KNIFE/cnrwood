# Build context excludes — keep image small and reproducible

.git
.github
.gitignore
.gitattributes

# Dependencies (rebuilt inside the image)
node_modules
vendor

# Built assets (regenerated by the assets stage)
public/build
public/hot
public/storage

# Local runtime + dev artifacts
storage/app/public/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/testing/*
storage/framework/views/*
storage/logs/*
bootstrap/cache/*.php

# Env / local config — provide via Compose env_file or environment
.env
.env.*
!.env.example

# Editor + OS noise
.idea
.vscode
.fleet
.DS_Store
Thumbs.db

# Test artifacts
.phpunit.cache
.phpunit.result.cache
coverage
phpunit.xml.bak

# Docs / misc
docs
README.md
CLAUDE.md

# Docker meta (no need to re-COPY into the image)
docker-compose*.yml
Dockerfile
.dockerignore
